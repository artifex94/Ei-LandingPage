# ──────────────────────────────────────────────────────────────────────────
# EscobarInstalaciones — plantilla de variables de entorno
# ──────────────────────────────────────────────────────────────────────────
# Copiar a `.env` (NO se versiona) y completar con los valores reales.
#
# Leyenda:
#   [BUILD]   se hornean durante `npm run build`. En deploy build-on-server
#             DEBEN estar presentes en el servidor ANTES de compilar.
#             Todas las NEXT_PUBLIC_* quedan embebidas en el bundle del cliente.
#   [RUNTIME] solo se leen cuando la app está corriendo. Pueden cargarse en el
#             panel de Hostinger como variables de entorno del proceso.
# ──────────────────────────────────────────────────────────────────────────

# ── [BUILD] Públicas (NEXT_PUBLIC_*) — visibles en el browser ───────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=https://instalacionescob.ar
NEXT_PUBLIC_BUSINESS_ALIAS=
NEXT_PUBLIC_BUSINESS_CVU=
NEXT_PUBLIC_WHATSAPP_NUMBER=

# ── [RUNTIME] Base de datos (Postgres / Supabase) ───────────────────────────
# Pooler de Supavisor en runtime. Las migraciones (prisma migrate) usan la URL
# directa vía prisma.config.ts; en producción no se corren migraciones.
DATABASE_URL=

# ── [RUNTIME] Supabase server-side (ignora RLS — service role) ──────────────
SUPABASE_SERVICE_ROLE_KEY=

# ── [RUNTIME] Acceso admin / cron ───────────────────────────────────────────
ADMIN_EMAIL_DOMAIN=
CRON_SECRET=

# ── [RUNTIME] Pagos — Mercado Pago ──────────────────────────────────────────
MP_ACCESS_TOKEN=
MP_WEBHOOK_SECRET=

# ── [RUNTIME] Pagos — Talo ──────────────────────────────────────────────────
TALO_API_KEY=
TALO_USER_ID=
TALO_WEBHOOK_SECRET=

# ── [RUNTIME] WhatsApp — Twilio ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_COUNTRY_PREFIX=54
TWILIO_TEMPLATE_LOGIN=
TWILIO_TEMPLATE_MOROSIDAD=

# ── SoftGuard — API web + DSS embed ─────────────────────────────────────────
# [RUNTIME] API de SoftGuard
SOFTGUARD_API_BASE=
SOFTGUARD_API_USER=
SOFTGUARD_API_PASS=
SOFTGUARD_API_CLIENT_ID=
SOFTGUARD_API_TIMEOUT_MS=10000
SOFTGUARD_FALLO_SOSTENIDO_HORAS=24
# [BUILD] SOFTGUARD_DSS_HOST se lee en next.config.ts para el CSP de /embed/*.
# Si cambia la IP/host del DSS, hay que RE-BUILDEAR para que tome efecto.
SOFTGUARD_DSS_HOST=localhost
SOFTGUARD_DSS_ORIGIN=
SOFTGUARD_EMBED_SECRET=

# ── Scripts / testing (no necesarias en producción) ─────────────────────────
# DRY_RUN=1
# RAMIRO_TELEFONO=
