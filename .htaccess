# ─── MIME types ───────────────────────────────────────────────────────────────
<IfModule mod_mime.c>
    AddType application/javascript         .js .mjs
    AddType text/css                       .css
    AddType font/woff2                     .woff2
    AddType font/woff                      .woff
    AddType image/svg+xml                  .svg
    AddType application/json               .json
    AddType image/png                      .png
    AddType image/jpeg                     .jpg .jpeg
    AddType image/x-icon                   .ico
    AddType application/manifest+json      .webmanifest
</IfModule>

# ─── Headers RSC — limpiar para evitar que Hostinger reenvíe headers de
# navegación cliente que hacen que Next.js devuelva payload RSC en vez de HTML ─
<IfModule mod_headers.c>
    RequestHeader unset RSC
    RequestHeader unset Next-Router-State-Tree
    RequestHeader unset Next-Router-Prefetch
    RequestHeader unset Next-Action
    RequestHeader set X-Forwarded-Proto "https"
</IfModule>
